{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipkit.local/schemas/execution-batch.schema.json",
  "title": "ShipKitExecutionBatch",
  "type": "object",
  "required": [
    "batch",
    "status",
    "summary",
    "artifacts",
    "checks_run",
    "follow_ups"
  ],
  "properties": {
    "batch": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["done", "partial", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "follow_ups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
