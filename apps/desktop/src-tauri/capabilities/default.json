{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Least-privilege capability set for the main ShipKit window",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "desktop-read",
    "desktop-write",
    "desktop-support",
    "updater:default",
    "process:default"
  ]
}
