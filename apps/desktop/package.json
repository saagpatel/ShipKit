{
  "name": "shipkit-desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ./scripts/dev-server.sh",
    "dev:tauri": "node ./scripts/tauri-dev.mjs",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:watch": "vitest",
    "tauri": "tauri",
    "lean:dev": "bash ./scripts/lean-dev.sh",
    "clean:heavy": "bash ./scripts/clean-heavy.sh",
    "clean:full": "bash ./scripts/clean-full.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@playwright/test": "^1.53.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^26.0.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3.1.1"
  }
}
